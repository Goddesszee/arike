# Anthropic API key — used for the consumer agent's reasoning (topic selection + synthesis)
ANTHROPIC_API_KEY=

# Set to true to run the full flow without a live Circle CLI session / funded wallet
MOCK=false

# Chain used for wallet + nanopayment calls (Arc Testnet once Circle CLI supports it directly;
# BASE is the CLI's documented default target for wallets/gateway in the current quickstarts)
ARIKE_CHAIN=BASE

# Cap per-service spend during discovery (USDC)
ARIKE_MAX_SPEND=0.02

# Port for ARIKE's own provider service (Port Congestion Index)
PROVIDER_PORT=4021

# Wallet address that should receive payments to ARIKE's provider service
# (get this from: circle wallet list --type agent --chain BASE)
ARIKE_PROVIDER_WALLET=

# --- Circle Contracts (for scripts/deploy-contracts.js) ---
# From Circle Console: console.circle.com
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
# Dev-controlled wallet ID on ARC-TESTNET, funded with testnet USDC (pays deploy gas)
ARIKE_DEPLOYER_WALLET_ID=
