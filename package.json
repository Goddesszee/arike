{
  "name": "arike",
  "version": "0.1.0",
  "private": true,
  "description": "ARIKE — an agent-to-agent data marketplace on Arc. Agents discover, evaluate, and pay other agents for data via Circle Nanopayments (x402), with no human in the loop.",
  "type": "module",
  "scripts": {
    "build": "node scripts/bundle-otp.js",
    "provider": "tsx src/provider/server.ts",
    "consumer": "tsx src/consumer/agent.ts",
    "consumer:mock": "tsx src/consumer/agent.ts --mock",
    "console": "tsx src/console/server.ts",
    "compile": "node scripts/compile.js",
    "deploy:contracts": "node scripts/deploy-contracts.js",
    "debug:deploy": "node scripts/debug-deploy-raw.js",
    "create:wallet": "node scripts/create-wallet.js",
    "try:swap": "tsx scripts/try-swap.ts",
    "try:bridge": "tsx scripts/try-bridge.ts",
    "try:send": "tsx scripts/try-send.ts",
    "try:balance": "tsx scripts/try-balance.ts",
    "try:paymaster": "tsx scripts/try-paymaster.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "@circle-fin/adapter-circle-wallets": "^1.4.2",
    "@circle-fin/adapter-viem-v2": "^1.13.0",
    "@circle-fin/app-kit": "^1.10.0",
    "@circle-fin/bridge-kit": "^1.12.0",
    "@circle-fin/developer-controlled-wallets": "^10.8.0",
    "@circle-fin/smart-contract-platform": "^10.8.0",
    "@circle-fin/swap-kit": "^1.3.2",
    "@circle-fin/unified-balance-kit": "^1.3.0",
    "@circle-fin/w3s-pw-web-sdk": "^1.1.11",
    "@circle-fin/x402-batching": "^3.2.0",
    "@x402/core": "^2.19.0",
    "@x402/evm": "^2.19.0",
    "dotenv": "^16.4.5",
    "esbuild": "^0.28.1",
    "esbuild-plugin-polyfill-node": "^0.3.0",
    "express": "^4.21.2",
    "permissionless": "^0.3.7",
    "solc": "^0.8.36",
    "viem": "^2.55.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@vercel/node": "^5.8.24",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
