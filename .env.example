# Anthropic API key — used for the consumer agent's reasoning (topic selection + synthesis)
ANTHROPIC_API_KEY=

# Set to true to run the full flow without a live Circle CLI session / funded wallet
MOCK=false

# Chain used for wallet + nanopayment calls (Arc Testnet once Circle CLI supports it directly;
# BASE is the CLI's documented default target for wallets/gateway in the current quickstarts)
ARIKE_CHAIN=BASE

# Cap per-service spend during discovery (USDC)
ARIKE_MAX_SPEND=0.02

# Port for ARIKE's own provider service (Port Congestion Index)
PROVIDER_PORT=4021

# Wallet address that should receive payments to ARIKE's provider service
# (get this from: circle wallet list --type agent --chain BASE)
ARIKE_PROVIDER_WALLET=

# --- Circle Contracts (for scripts/deploy-contracts.js) ---
# From Circle Console: console.circle.com
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
# Dev-controlled wallet ID on ARC-TESTNET, funded with testnet USDC (pays deploy gas)
ARIKE_DEPLOYER_WALLET_ID=

# --- ARIKE Console (src/console/server.ts) ---
CONSOLE_PORT=4022
# Set after running `npm run deploy:contracts` — enables live mode instead of mock data
ARIKE_LEDGER_ADDRESS=

# Dedicated wallet that pays gas for the public "Trigger agent purchase"
# button on the deployed Vercel dashboard. Use a SEPARATE wallet from your
# main deployer wallet — this one gets spent down by public clicks (testnet
# USDC only, refill anytime from faucet.circle.com). Set this + the four
# vars above in Vercel's project environment variables, not just locally.
ARIKE_DEMO_WALLET_ID=

# Wallet Set ID (from `npm run create:wallet`'s output) — used by the
# Bridge/Swap/Send/Balance panels' underlying Circle-managed wallet.
ARIKE_WALLET_SET_ID=

# --- Real Circle email-OTP login (src/console/otp-client.ts, api/circle-auth.ts) ---
# From Circle Console: Wallets -> User Controlled -> Configurator.
# Requires SMTP credentials configured there too (Mailtrap sandbox works for
# testing) — see CIRCLE_SETUP.md section on OTP login for the full walkthrough.
ARIKE_CIRCLE_APP_ID=

# --- CCTP Bridge (src/lib/bridge.ts) ---
# No longer needs a raw private key — uses your Circle-managed wallet via
# CIRCLE_API_KEY/CIRCLE_ENTITY_SECRET above (already set for Contracts).

# --- Swap (src/lib/swap.ts) ---
# Free "kit key" from the Circle Console — separate from CIRCLE_API_KEY.
CIRCLE_KIT_KEY=

# Onchain address (0x...) of the wallet Bridge/Swap operate through —
# same wallet as ARIKE_DEPLOYER_WALLET_ID, just its address form
ARIKE_DEPLOYER_WALLET_ADDRESS=

# --- Paymaster (src/lib/paymaster.ts) ---
# Only needed for the Base-side flow (a provider agent's smart account
# paying gas in USDC instead of ETH). Get a free key at pimlico.io
PIMLICO_API_KEY=
# Owner key for the Base Sepolia smart account (needs a small USDC balance
# on Base Sepolia — faucet.circle.com, select Base Sepolia). Use a
# dedicated throwaway key, never a real wallet's private key.
PAYMASTER_PRIVATE_KEY=
